# Copy this file to .env.local and fill in the values.
# .env.local is gitignored (see .gitignore → ".env*.local").

# Supabase project URL and the publishable (anon) key for browser-side reads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service-role key. NEVER expose to the browser. Used by:
#   - /forms/[id] (public signing page, RLS bypassed so unauthenticated
#     clients can load their form)
#   - /api/upload-signed-pdf (storage upload as the agent)
# Paste the real value from Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Browserless token (https://browserless.io). Used by /api/generate-pdf.
# Without this, /api/generate-pdf returns HTTP 500.
BROWSERLESS_TOKEN=
